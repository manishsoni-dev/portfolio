---
import { getCollection, render } from "astro:content";
import { existsSync } from "node:fs";
import { join } from "node:path";
import ButtonLink from "../../components/ButtonLink.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import TagList from "../../components/TagList.astro";
import { site } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const pageTitle = `${project.data.title} | ${site.title}`;
const pageDescription = project.data.summary;
const detailLabels = project.data.labels;
const liveDemoUrl = project.data.liveDemoUrl ?? project.data.demo;
const repoUrl = project.data.repoUrl ?? project.data.repository;
const apiUrl = project.data.apiUrl ?? project.data.liveApi;
const proofUrl = project.data.proofUrl ?? project.data.proof;
const demoVideoUrl = project.data.demoVideoUrl ?? project.data.videoUrl;
const proofLinks = [
  liveDemoUrl && { href: liveDemoUrl, label: "Live Demo" },
  repoUrl && { href: repoUrl, label: "Repository" },
  apiUrl && { href: apiUrl, label: "Live API / Health" },
  proofUrl && { href: proofUrl, label: "Proof PR" },
].filter(Boolean) as { href: string; label: string }[];

type MediaInput = string | { src: string; alt?: string; caption?: string };
type MediaItem = { src: string; alt: string; caption: string };

function isRenderableAsset(src: string): boolean {
  if (src.startsWith("http://") || src.startsWith("https://")) {
    return true;
  }

  if (!src.startsWith("/")) {
    return false;
  }

  return existsSync(join(process.cwd(), "public", src));
}

function normalizeMediaItem(item: MediaInput, fallbackCaption: string): MediaItem | undefined {
  const src = typeof item === "string" ? item : item.src;

  if (!src || !isRenderableAsset(src)) {
    return undefined;
  }

  const alt = typeof item === "string" ? fallbackCaption : item.alt ?? fallbackCaption;
  const caption = typeof item === "string" ? fallbackCaption : item.caption ?? fallbackCaption;

  return { src, alt, caption };
}

const proofMedia = [
  ...project.data.screenshots.map((item) => normalizeMediaItem(item, "Project screenshot")),
  ...project.data.screenshotUrls.map((item) => normalizeMediaItem(item, "Project screenshot")),
  ...project.data.proofImageUrls.map((item) => normalizeMediaItem(item, "Project proof image")),
].filter(Boolean) as MediaItem[];

const uniqueProofMedia = proofMedia.filter(
  (item, index, items) => items.findIndex((candidate) => candidate.src === item.src) === index,
);
const hasProjectProof = uniqueProofMedia.length > 0 || Boolean(demoVideoUrl) || proofLinks.length > 0;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="premium-page-bg min-h-screen">
  <SiteHeader />
  <main id="main-content">
    <article class="mx-auto max-w-3xl px-5 py-14 sm:py-20 lg:px-8">
      <a
        href="/"
        class="inline-flex text-[14px] font-semibold text-portfolio-accent-dark underline underline-offset-4 transition-colors hover:text-portfolio-accent"
      >
        Back to portfolio
      </a>

      <header class="premium-surface mt-10 rounded-lg border border-portfolio-line bg-portfolio-surface p-6 sm:p-8">
        <p class="font-mono text-[13px] font-semibold uppercase tracking-[0.1em] text-portfolio-accent">
          Project
        </p>

        {
          detailLabels.length > 0 && (
            <ul class="mt-4 flex flex-wrap gap-2">
              {detailLabels.map((label) => (
                <li
                  class:list={[
                    "rounded-full border px-3 py-1 font-mono text-[13px] font-semibold",
                    label === "Featured"
                      ? "border-portfolio-accent bg-portfolio-accent text-portfolio-dark-text"
                      : "border-portfolio-accent/15 bg-portfolio-soft text-portfolio-accent-dark",
                  ]}
                >
                  {label}
                </li>
              ))}
            </ul>
          )
        }

        <h1 class="mt-4 font-display text-4xl font-semibold leading-tight tracking-normal text-portfolio-ink sm:text-5xl">
          {project.data.title}
        </h1>
        <p class="mt-5 text-lg leading-8 text-portfolio-muted">{project.data.summary}</p>
        {project.data.problem && (
          <p class="mt-4 text-base leading-8 text-portfolio-muted">
            <span class="font-medium text-portfolio-ink">Problem:</span> {project.data.problem}
          </p>
        )}

        {
          project.data.role && (
            <p class="mt-5 text-[14px] leading-6 text-portfolio-muted">
              <span class="font-medium text-portfolio-ink">Role:</span> {project.data.role}
            </p>
          )
        }

        <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          {
            liveDemoUrl ? (
              <ButtonLink href={liveDemoUrl} label="Live Demo Experience" variant="primary" external />
            ) : (
              <span class="glass-control glass-control-secondary inline-flex min-h-12 items-center justify-center rounded-md border px-5 text-[15px] font-semibold text-portfolio-muted">
                Demo coming soon
              </span>
            )
          }

          {
            repoUrl ? (
              <ButtonLink href={repoUrl} label="Source Repository" external />
            ) : (
              <span class="glass-control glass-control-secondary inline-flex min-h-12 items-center justify-center rounded-md border px-5 text-[15px] font-semibold text-portfolio-muted">
                Source repository coming soon
              </span>
            )
          }

          {apiUrl && <ButtonLink href={apiUrl} label="Live API" external />}
          {proofUrl && <ButtonLink href={proofUrl} label="Proof Link" external />}
          {demoVideoUrl && <ButtonLink href={demoVideoUrl} label="Video" external />}
          <ButtonLink href="/#projects" label="Back to Projects" />
        </div>

        {project.data.stack.length > 0 && <TagList items={project.data.stack} class="mt-6" />}
      </header>

      <div class="project-content mt-10 leading-8 text-portfolio-muted">
        <Content />
      </div>

      {hasProjectProof && (
          <section class="mt-14 border-t border-portfolio-line pt-10">
            <p class="font-mono text-[13px] font-semibold uppercase tracking-[0.1em] text-portfolio-accent">
              Project Proof
            </p>
            <h2 class="mt-3 font-display text-3xl font-semibold leading-tight text-portfolio-ink">
              Screenshots, proof links, and inspectable artifacts.
            </h2>

            {uniqueProofMedia.length > 0 && (
              <div class="mt-6 grid gap-6">
                {uniqueProofMedia.map((screenshot) => (
                <figure class="premium-surface overflow-hidden rounded-lg border border-portfolio-line bg-portfolio-surface">
                  <img
                    src={screenshot.src}
                    alt={screenshot.alt}
                    loading="lazy"
                    class="aspect-video w-full bg-portfolio-bg object-cover"
                  />
                  <figcaption class="border-t border-portfolio-line px-5 py-4 text-[15px] leading-7 text-portfolio-muted">
                    {screenshot.caption}
                  </figcaption>
                </figure>
                ))}
              </div>
            )}

            {demoVideoUrl && (
              <div class="mt-6">
                <ButtonLink href={demoVideoUrl} label="Demo Video" external />
              </div>
            )}

            {proofLinks.length > 0 && (
              <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                {proofLinks.map((link) => (
                  <ButtonLink href={link.href} label={link.label} external />
                ))}
              </div>
            )}
          </section>
      )}
    </article>
  </main>
  <SiteFooter />
  </div>
</BaseLayout>
