---
const availableFor = [
  "AI Engineer Intern",
  "GenAI Intern",
  "Backend AI Intern",
  "Python Developer Intern",
  "Developer Tools Intern",
  "Software Engineering Intern",
];

const coreProof = [
  "GitHub PR AI review bot",
  "AI analytics platform",
  "repository repair automation",
];

const strengths = [
  "Python",
  "TypeScript",
  "LLM Applications",
  "RAG-style Retrieval",
  "Backend APIs",
  "GitHub Developer Tools",
];
---

<section class="bg-portfolio-bg">
  <div class="mx-auto max-w-6xl px-5 py-16 lg:px-8">
    <div class="mb-7">
      <p class="font-mono text-[13px] font-semibold uppercase tracking-[0.1em] text-portfolio-accent">
        Recruiter Quick Scan
      </p>
      <h2 class="mt-3 max-w-3xl font-display text-3xl font-semibold leading-tight text-portfolio-ink sm:text-4xl">
        Practical AI/backend fit, readable in one pass.
      </h2>
    </div>

    <div class="premium-surface grid gap-6 rounded-xl border border-portfolio-line bg-portfolio-surface p-6 md:grid-cols-2 lg:grid-cols-4 lg:p-8">
      <div>
        <p class="font-mono text-[13px] font-semibold uppercase tracking-[0.1em] text-portfolio-accent">
          Available for
        </p>
        <p class="mt-3 text-base font-semibold leading-7 text-portfolio-ink">
          {availableFor.join(" · ")}
        </p>
      </div>

      <div>
        <p class="font-mono text-[13px] font-semibold uppercase tracking-[0.1em] text-portfolio-accent">
          Core proof
        </p>
        <p class="mt-3 text-base font-semibold leading-7 text-portfolio-ink">
          {coreProof.join(" · ")}
        </p>
      </div>

      <div>
        <p class="font-mono text-[13px] font-semibold uppercase tracking-[0.1em] text-portfolio-accent">
          Strengths
        </p>
        <p class="mt-3 text-base font-semibold leading-7 text-portfolio-ink">
          {strengths.join(" · ")}
        </p>
      </div>

      <div>
        <p class="font-mono text-[13px] font-semibold uppercase tracking-[0.1em] text-portfolio-accent">
          Location
        </p>
        <p class="mt-3 text-base font-semibold leading-7 text-portfolio-ink">
          India · Open to remote and India-based internships
        </p>
      </div>
    </div>
  </div>
</section>
