---
// src/components/SocialLinks.astro

interface Props {
  /** Use "light" on dark backgrounds (footer/contact), "dark" on light backgrounds (hero). */
  variant?: "dark" | "light";
  /** Filter which links to show. "career" = LinkedIn, GitHub, X. "personal" = YouTube, Instagram, Facebook. "all" = everything. */
  filter?: "career" | "personal" | "all";
}

const { variant = "dark", filter = "all" } = Astro.props;

const allSocials = [
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/manishsoni-dev",
    icon: "linkedin",
    group: "career" as const,
  },
  {
    name: "GitHub",
    href: "https://github.com/manishsoni-dev",
    icon: "github",
    group: "career" as const,
  },
  {
    name: "X",
    href: "https://x.com/manishsoni_dev",
    icon: "x",
    group: "career" as const,
  },
  {
    name: "YouTube",
    href: "https://www.youtube.com/@hahamanish",
    icon: "youtube",
    group: "personal" as const,
  },
  {
    name: "Instagram",
    href: "https://www.instagram.com/hiemanish/",
    icon: "instagram",
    group: "personal" as const,
  },
  {
    name: "Facebook",
    href: "https://www.facebook.com/hiemanish",
    icon: "facebook",
    group: "personal" as const,
  },
];

const socials = filter === "all"
  ? allSocials
  : allSocials.filter((s) => s.group === filter);

const variantClasses =
  variant === "light"
    ? "border-portfolio-dark-text/20 text-portfolio-dark-text/80 hover:border-portfolio-accent hover:bg-portfolio-accent/10 hover:text-portfolio-accent-soft"
    : "border-portfolio-line text-portfolio-muted hover:border-portfolio-accent hover:bg-portfolio-soft hover:text-portfolio-accent";
---

<div class="flex flex-wrap items-center justify-center gap-3">
  {socials.map((social) => (
    <a
      href={social.href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={social.name}
      title={social.name}
      class:list={[
        "glass-control glass-control-secondary inline-flex h-10 w-10 items-center justify-center rounded-md border transition-all duration-200 hover:-translate-y-0.5 hover:shadow-sm",
        variantClasses,
      ]}
    >
      <span class="sr-only">{social.name}</span>

      {social.icon === "linkedin" && (
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V24h-4V8zm7.5 0h3.8v2.2h.1c.5-1 1.9-2.2 3.9-2.2 4.2 0 5 2.8 5 6.4V24h-4v-8.5c0-2 0-4.6-2.8-4.6s-3.2 2.2-3.2 4.5V24h-4V8z" />
        </svg>
      )}

      {social.icon === "github" && (
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M12 .5A12 12 0 0 0 8.2 23.9c.6.1.8-.2.8-.6v-2.1c-3.3.7-4-1.4-4-1.4-.5-1.3-1.2-1.6-1.2-1.6-1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 .1.7 2.1 3.4 1.5.1-.7.4-1.2.7-1.5-2.6-.3-5.4-1.3-5.4-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.3 0 0 1-.3 3.3 1.2A11.2 11.2 0 0 1 12 6.9c1 0 2 .1 3 .4 2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 3 .1 3.3.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.4 5.9.4.3.8 1 .8 2v2.9c0 .4.2.7.8.6A12 12 0 0 0 12 .5z" />
        </svg>
      )}

      {social.icon === "x" && (
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M18.9 2H22l-6.8 7.8L23.2 22h-6.3l-4.9-7.4L6.4 22H3.2l7.3-8.4L2.8 2h6.5l4.4 6.6L18.9 2zm-1.1 17.9h1.7L8.4 4H6.6l11.2 15.9z" />
        </svg>
      )}

      {social.icon === "youtube" && (
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.6 15.5v-7l6.2 3.5-6.2 3.5z" />
        </svg>
      )}

      {social.icon === "instagram" && (
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm0 2a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3H7zm5 3.8A4.2 4.2 0 1 1 12 16.2 4.2 4.2 0 0 1 12 7.8zm0 2A2.2 2.2 0 1 0 12 14.2 2.2 2.2 0 0 0 12 9.8zM17.4 6.6a1 1 0 1 1-1 1 1 1 0 0 1 1-1z" />
        </svg>
      )}

      {social.icon === "facebook" && (
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
          <path d="M22 12a10 10 0 1 0-11.6 9.9v-7h-2.5V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.4h-1.2c-1.2 0-1.6.8-1.6 1.5v2h2.7l-.4 2.9h-2.3v7A10 10 0 0 0 22 12z" />
        </svg>
      )}
    </a>
  ))}
</div>
