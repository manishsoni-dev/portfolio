---
import { hasResumeAsset, resumeAsset } from "../data/assets";
import { profile } from "../data/profile";
import ButtonLink from "./ButtonLink.astro";

const showResumeLink = hasResumeAsset();
---

<section class="relative isolate min-h-[min(720px,74svh)] overflow-hidden border-b border-white/10 bg-black/10">
  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(5,6,8,0.08)_0%,rgba(5,6,8,0.28)_54%,rgba(5,6,8,0.94)_100%)]"></div>
  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(90deg,rgba(5,6,8,0.66)_0%,rgba(5,6,8,0.12)_48%,rgba(5,6,8,0.5)_100%)]"></div>

  <div class="relative z-10 mx-auto flex min-h-[min(720px,74svh)] max-w-6xl flex-col justify-center px-5 py-12 sm:py-16 lg:px-8">
    <div class="max-w-4xl">
    <p
      class="glass-chip mb-7 inline-flex items-center gap-2 rounded-full border border-white/15 px-4 py-2 font-mono text-[12px] font-semibold text-white/80"
    >
      <span class="status-dot" aria-hidden="true"></span>
      {profile.availability}
    </p>

    <h1
      class="font-display text-5xl font-bold leading-[0.96] tracking-normal text-white sm:text-7xl lg:text-8xl"
    >
      {profile.name}
    </h1>

    <p class="mt-7 max-w-3xl text-lg leading-8 text-white/78 sm:text-xl sm:leading-9">
      {profile.headline}
    </p>

    <p class="mt-4 max-w-2xl font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-portfolio-accent-soft">
      {profile.role}
    </p>

    <div class="mt-8 grid max-w-md grid-cols-2 gap-3">
      <ButtonLink
        href="#projects"
        label="View Projects"
        variant="primary"
        aria-label="View selected projects"
        title="View Projects"
      />
      {showResumeLink && (
        <ButtonLink
          href={resumeAsset.path}
          label="Download Resume"
          variant="primary"
          aria-label="Download Resume"
          title="Download Resume"
        />
      )}
      {!showResumeLink && (
        <span
          class="glass-control glass-control-secondary inline-flex min-h-12 items-center justify-center rounded-md border px-5 text-[15px] font-semibold text-portfolio-muted"
          aria-label="Resume coming soon"
          title="Resume coming soon"
        >
          Resume coming soon
        </span>
      )}
    </div>
    <div class="mt-5 flex flex-wrap gap-x-6 gap-y-3 text-[14px] font-semibold text-white/72">
      <a class="transition-colors hover:text-portfolio-accent" href={profile.links.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a class="transition-colors hover:text-portfolio-accent" href={profile.links.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a class="transition-colors hover:text-portfolio-accent" href={profile.links.email}>Email me</a>
    </div>
    </div>

    <dl class="mt-8 grid max-w-3xl grid-cols-2 gap-x-8 gap-y-5 border-t border-white/16 pt-5 text-sm sm:mt-10 sm:grid-cols-3 sm:pt-6">
      <div>
        <dt class="font-mono text-[11px] uppercase text-white/45">Education</dt>
        <dd class="mt-2 font-semibold text-white/88">{profile.education}</dd>
      </div>
      <div>
        <dt class="font-mono text-[11px] uppercase text-white/45">Location</dt>
        <dd class="mt-2 font-semibold text-white/88">{profile.location}</dd>
      </div>
      <div class="col-span-2 sm:col-span-1">
        <dt class="font-mono text-[11px] uppercase text-white/45">Focus</dt>
        <dd class="mt-2 font-semibold text-white/88">Applied AI systems</dd>
      </div>
    </dl>
  </div>
</section>
