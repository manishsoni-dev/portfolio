---
import { profile } from "../data/profile";
import SocialLinks from "./SocialLinks.astro";
---

<footer class="border-t border-portfolio-dark-text/10 bg-portfolio-dark-bg px-5 py-10 text-portfolio-dark-text lg:px-8">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-5 sm:flex-row sm:justify-between">
    <p class="text-[14px] font-medium text-portfolio-dark-text/70">
      {profile.name} · {profile.location}
    </p>
    <SocialLinks variant="light" />
  </div>
</footer>
