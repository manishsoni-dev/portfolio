---
import { profile } from "../data/profile";
---

<section class="glass-band border-y border-portfolio-line">
  <div class="mx-auto max-w-6xl px-5 py-18 lg:px-8">
    <p class="font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-portfolio-accent">
      Currently targeting
    </p>

    <ul class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {profile.targetRoles.map((role) => (
        <li class="glass-chip surface-hover rounded-md border border-portfolio-line px-4 py-4 text-[15px] font-semibold text-portfolio-ink">
          {role}
        </li>
      ))}
    </ul>
  </div>
</section>
