---
interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary";
  external?: boolean;
  [key: string]: any;
}

const { href, label, variant = "secondary", external = false, ...rest } = Astro.props;

const baseClass =
  "glass-control inline-flex min-h-12 items-center justify-center rounded-md border px-4 text-[15px] font-semibold tracking-normal transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-portfolio-accent sm:px-5";

const variantClass =
  variant === "primary"
    ? "glass-control-primary border-white text-[#07090d] hover:-translate-y-0.5 hover:border-portfolio-accent hover:bg-portfolio-accent"
    : "glass-control-secondary text-white hover:-translate-y-0.5 hover:border-portfolio-accent/50 hover:bg-white/[0.08] hover:text-portfolio-accent";
---

<a
  href={href}
  class={`${baseClass} ${variantClass}`}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  {...rest}
>
  {label}
</a>
