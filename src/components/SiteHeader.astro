---
import { profile } from "../data/profile";

interface Props {
  showProjects?: boolean;
}

const { showProjects = false } = Astro.props;
const isHome = Astro.url.pathname === "/";
const sectionHref = (id: string) => isHome ? `#${id}` : `/#${id}`;
---

<header class="glass-nav sticky top-0 z-40 border-b border-white/10">
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-5 px-5 py-4 lg:px-8"
    aria-label="Primary navigation"
  >
    <a
      href="/"
      class="font-display text-lg font-bold tracking-normal text-white transition-colors hover:text-portfolio-accent"
      aria-label="Manish Soni home"
    >
      {profile.logo}
    </a>

    <div class="flex items-center gap-x-4 text-[13px] font-medium text-portfolio-muted sm:gap-x-6 sm:text-[14px]">
      <a class="hidden transition-colors hover:text-portfolio-accent sm:inline" href={showProjects ? "#projects" : "/projects/"}>Projects</a>
      <a class="hidden transition-colors hover:text-portfolio-accent sm:inline" href={sectionHref("skills")}>Skills</a>
      <a class="hidden transition-colors hover:text-portfolio-accent md:inline" href={sectionHref("profile")}>Profile</a>
      <a class="transition-colors hover:text-portfolio-accent" href="/hire-me/">Hire Me</a>
      <a class="glass-control glass-control-secondary rounded-md border px-3 py-2 text-white transition-colors hover:border-portfolio-accent/45 hover:text-portfolio-accent" href={sectionHref("contact")}>Contact</a>
    </div>
  </nav>
</header>
