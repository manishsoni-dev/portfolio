---
interface Props {
  eyebrow: string;
  title: string;
}

const { eyebrow, title } = Astro.props;
---

<div class="mb-10 grid gap-4 md:grid-cols-[11rem_1fr] md:items-start">
  <p class="font-mono text-[12px] font-semibold uppercase tracking-[0.1em] text-portfolio-accent">
    {eyebrow}
  </p>
  <h2 class="max-w-3xl font-display text-3xl font-semibold leading-tight tracking-normal text-portfolio-ink sm:text-4xl">
    {title}
  </h2>
</div>
