---
interface Props {
  items: readonly string[];
  class?: string;
}

const { items, class: className = "" } = Astro.props;
---

<ul class:list={["flex flex-wrap gap-2", className]}>
  {
    items.map((item) => (
      <li class="rounded-md border border-portfolio-accent/15 bg-portfolio-soft px-3 py-1.5 font-mono text-[13px] font-medium text-portfolio-accent-dark">
        {item}
      </li>
    ))
  }
</ul>
